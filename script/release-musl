#!/bin/sh

# script/release: build binaries in all supported platforms and upload them with the gh client

set -e

cd "$(dirname "$0")/.."

if [ -z "$1" ]; then
    echo "Usage: $0 <version>"
    exit 1
fi

# If a GitHub App key will be used to mint the release token later, validate it now
# so a bad/unreadable key fails in seconds instead of after the ~60-minute build.
if [ -z "$GH_TOKEN" ] && [ -n "$GH_APP_ID" ] && [ -n "$GH_APP_INSTALLATION_ID" ] && [ -n "$GH_APP_PRIVATE_KEY_PATH" ]; then
    if [ ! -f "$GH_APP_PRIVATE_KEY_PATH" ]; then
        echo "Private key not found at: $GH_APP_PRIVATE_KEY_PATH" >&2
        exit 1
    fi
    if ! openssl pkey -in "$GH_APP_PRIVATE_KEY_PATH" -noout 2>/dev/null; then
        echo "GH_APP_PRIVATE_KEY_PATH is not a private key openssl can load (check PEM format / encryption)." >&2
        exit 1
    fi
fi

echo "Running bootstrap to install build tools (upx, linters, …)"
date "+%H:%M:%S"
./script/bootstrap

echo "Checking if gh is installed…"
date "+%H:%M:%S"

if ! type "gh" > /dev/null; then
    echo "gh not found installing…"
    date "+%H:%M:%S"
    OS="`uname`"
    case $OS in
      'Linux')
        if type "apt" > /dev/null; then
            echo "detected debian based system installing via apt"
            curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
            echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
            sudo apt update -y
            sudo apt install gh -y 
        fi
        if type "yum" > /dev/null; then
            echo "detected rpm based system installing via yum"
            sudo dnf install 'dnf-command(config-manager)' -y
            sudo dnf config-manager --add-repo https://cli.github.com/packages/rpm/gh-cli.repo
            sudo dnf install gh -y
        fi
        ;;
      'WindowsNT')
        echo "install gh and try again https://github.com/cli/cli/releases"
        exit 1
        ;;
      'Darwin') 
        if type "brew" > /dev/null; then
            brew install gh
        else
            echo "install homebrew to have zip https://brew.sh/"
            exit 1
        fi
        ;;
      *) ;;
      esac
fi

# this is also set in script/build-release and is a copy paste
GIT_SHA=`git rev-parse --short HEAD`
VERSION=$1

./script/release-build-musl $VERSION

# Authenticate AFTER the build. The build takes ~60+ minutes, and a GitHub App
# installation token is only valid for 1 hour, so a token minted before the build
# would expire before the upload. Mint it here, seconds before it is used.
#
# If GH_TOKEN is already set (e.g. a long-lived PAT) it is used as-is. Otherwise a
# fresh installation token is generated from the GitHub App private key. In Jenkins,
# provide GH_APP_PRIVATE_KEY_PATH via a "Secret file" credential binding, and
# GH_APP_ID / GH_APP_INSTALLATION_ID as secret text — do NOT bind the "GitHub App"
# credential to GH_TOKEN (that token is minted at step start and expires mid-build).
if [ -z "$GH_TOKEN" ]; then
    if [ -z "$GH_APP_ID" ] || [ -z "$GH_APP_INSTALLATION_ID" ] || [ -z "$GH_APP_PRIVATE_KEY_PATH" ]; then
        echo "GH_TOKEN not set and GitHub App credentials not provided." >&2
        echo "Set GH_TOKEN, or set GH_APP_ID, GH_APP_INSTALLATION_ID, and GH_APP_PRIVATE_KEY_PATH." >&2
        exit 1
    fi

    if ! type "openssl" > /dev/null 2>&1; then
        echo "Required command not found: openssl" >&2
        exit 1
    fi

    if [ ! -f "$GH_APP_PRIVATE_KEY_PATH" ]; then
        echo "Private key not found at: $GH_APP_PRIVATE_KEY_PATH" >&2
        exit 1
    fi

    echo "Generating installation token from GitHub App…"
    date "+%H:%M:%S"

    now=$(date +%s)
    iat=$((now - 60))    # back-dated 60s to allow for clock drift
    exp=$((now + 570))   # 9.5 minutes, under GitHub's 10 minute JWT limit

    # tr -d '\n' guards against openssl builds that ignore -A and wrap base64 at
    # 64 chars — embedded newlines would corrupt the JWT ("could not be decoded").
    b64enc() {
        openssl base64 -A | tr -d '\n' | tr '+/' '-_' | tr -d '='
    }

    jwt_header=$(printf '{"alg":"RS256","typ":"JWT"}' | b64enc)
    jwt_payload=$(printf '{"iat":%s,"exp":%s,"iss":"%s"}' "$iat" "$exp" "$GH_APP_ID" | b64enc)
    jwt_unsigned="${jwt_header}.${jwt_payload}"
    jwt_signature=$(printf '%s' "$jwt_unsigned" | openssl dgst -sha256 -sign "$GH_APP_PRIVATE_KEY_PATH" | b64enc)
    if [ -z "$jwt_signature" ]; then
        echo "openssl produced an empty JWT signature — GH_APP_PRIVATE_KEY_PATH is not a usable RSA key." >&2
        exit 1
    fi
    APP_JWT="${jwt_unsigned}.${jwt_signature}"

    # Safe diagnostic (no secrets): segment lengths and newline count. A well-formed
    # JWT has 0 newlines and a non-empty signature (~342 chars for a 2048-bit key).
    echo "JWT header/payload/sig chars: ${#jwt_header}/${#jwt_payload}/${#jwt_signature}; newlines: $(printf '%s' "$APP_JWT" | tr -cd '\n' | wc -c | tr -d ' ')"

    # Use gh itself (authenticated via the App JWT) to request the installation token,
    # and extract it with gh's built-in --jq so no external jq dependency is needed.
    GH_TOKEN=$(GH_TOKEN="$APP_JWT" gh api \
        --method POST \
        -H "Accept: application/vnd.github+json" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        --jq '.token' \
        "/app/installations/${GH_APP_INSTALLATION_ID}/access_tokens")
    unset APP_JWT

    if [ -z "$GH_TOKEN" ]; then
        echo "Failed to obtain installation token." >&2
        exit 1
    fi

    export GH_TOKEN
fi

gh release create $VERSION --title $VERSION --generate-notes  ./bin/ddc-windows-amd64.zip ./bin/ddc-windows-arm64.zip ./bin/ddc-mac-m-series.zip ./bin/ddc-mac-intel.zip ./bin/ddc-linux-arm64.zip ./bin/ddc-linux-amd64.zip

